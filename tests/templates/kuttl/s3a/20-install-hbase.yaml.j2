---
apiVersion: hbase.stackable.tech/v1alpha1
kind: HbaseCluster
metadata:
  name: test-hbase
spec:
  image:
{% if test_scenario['values']['hbase'].find(",") > 0 %}
    custom: "{{ test_scenario['values']['hbase'].split(',')[1] }}"
    productVersion: "{{ test_scenario['values']['hbase'].split(',')[0] }}"
{% else %}
    productVersion: "{{ test_scenario['values']['hbase'] }}"
{% endif %}
    pullPolicy: IfNotPresent
  clusterConfig:
    hdfsConfigMapName: test-hdfs
    zookeeperConfigMapName: test-znode
{% if lookup('env', 'VECTOR_AGGREGATOR') %}
    vectorAggregatorConfigMapName: vector-aggregator-discovery
{% endif %}
  masters:
    config:
      logging:
        enableVectorAgent: {{ lookup('env', 'VECTOR_AGGREGATOR') | length > 0 }}
    roleGroups:
      default:
        config:
          hbaseRootdir: s3a://hbase-root/
        configOverrides:
          hbase-site.xml:
            fs.s3a.endpoint: http://minio:9000/
            fs.s3a.connection.ssl.enabled: "false"
            fs.s3a.path.style.access: "true"
            fs.s3a.committer.name: magic
            hbase.wal.dir: hdfs://test-hdfs/hbase
          hbase-env.sh:
            HBASE_CLASSPATH: /stackable/hadoop/share/hadoop/tools/lib/*.jar
            AWS_ACCESS_KEY_ID: hbaseAccessKey
            AWS_SECRET_KEY: hbaseSecretKey
        replicas: 1
  regionServers:
    config:
      logging:
        enableVectorAgent: {{ lookup('env', 'VECTOR_AGGREGATOR') | length > 0 }}
    roleGroups:
      default:
        config:
          hbaseRootdir: s3a://hbase-root/
        configOverrides:
          hbase-site.xml:
            fs.s3a.endpoint: http://minio:9000/
            fs.s3a.connection.ssl.enabled: "false"
            fs.s3a.path.style.access: "true"
            fs.s3a.committer.name: magic
            hbase.wal.dir: hdfs://test-hdfs/hbase
          hbase-env.sh:
            HBASE_CLASSPATH: /stackable/hadoop/share/hadoop/tools/lib/*.jar
            AWS_ACCESS_KEY_ID: hbaseAccessKey
            AWS_SECRET_KEY: hbaseSecretKey
        replicas: 1
  restServers:
    config:
      logging:
        enableVectorAgent: {{ lookup('env', 'VECTOR_AGGREGATOR') | length > 0 }}
    roleGroups:
      default:
        config:
          hbaseRootdir: s3a://hbase-root/
        configOverrides:
          hbase-site.xml:
            fs.s3a.endpoint: http://minio:9000/
            fs.s3a.connection.ssl.enabled: "false"
            fs.s3a.path.style.access: "true"
            fs.s3a.committer.name: magic
            hbase.wal.dir: hdfs://test-hdfs/hbase
          hbase-env.sh:
            HBASE_CLASSPATH: /stackable/hadoop/share/hadoop/tools/lib/*.jar
            AWS_ACCESS_KEY_ID: hbaseAccessKey
            AWS_SECRET_KEY: hbaseSecretKey
        replicas: 1
